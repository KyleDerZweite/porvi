---
---

<header class="hero hero-full">
  <div class="wrap">
    <h1 class="display display-xl reveal">
      Your personal<br />
      web presence,<br />
      <em>versioned</em>, and yours<br />
      to keep.
    </h1>

    <div class="hero-foot">
      <p class="lede reveal d1">
        Porvi is a creator-site platform built around structured content,
        clean revisions, and portable static output. You write in a real
        console, each publish is a numbered revision, and your site is served
        on <em>your</em> domain - not a subpath of ours.
      </p>

      <div class="hero-cta reveal d2">
        <a class="btn btn-primary" href="#cta">
          Request early access
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path
              d="M2.5 6h7M6 2.5 9.5 6 6 9.5"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
        <a class="btn btn-ghost" href="#how">See how it works</a>
      </div>
    </div>

    <a class="scroll-cue reveal d3" href="#features" aria-label="Scroll to explore">
      <span class="scroll-cue-label">Scroll</span>
      <span class="scroll-cue-rail" aria-hidden="true">
        <svg width="14" height="44" viewBox="0 0 14 44" fill="none">
          <path d="M7 2 v30" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
          <path d="M2 28 l5 6 5-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </a>

    <div class="hero-meta reveal">
      <div class="meta-cell">
        <div class="num">Structured</div>
        <div class="label">Content with a shape</div>
      </div>
      <div class="meta-cell">
        <div class="num"><em>Versioned</em></div>
        <div class="label">Every publish, kept</div>
      </div>
      <div class="meta-cell">
        <div class="num">Your domain</div>
        <div class="label">Certs handled for you</div>
      </div>
      <div class="meta-cell">
        <div class="num">Portable</div>
        <div class="label">Static output, yours</div>
      </div>
    </div>
  </div>
</header>
