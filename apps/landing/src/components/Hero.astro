---
import { getStrings, type Lang } from '../i18n/strings';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getStrings(lang);
---

<header class="hero hero-full">
  <div class="wrap">
    <h1 class="display display-xl reveal">
      {t.hero.titleLines.map((line) => (<>{line}<br /></>))}
      <em>{t.hero.titleEm}</em>{t.hero.titleTail}
    </h1>

    <div class="hero-foot">
      <p class="lede reveal d1">
        {t.hero.lede.before}<em>{t.hero.lede.em}</em>{t.hero.lede.after}
      </p>

      <div class="hero-cta reveal d2">
        <a class="btn btn-primary" href="#cta">
          {t.hero.ctaPrimary}
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path
              d="M2.5 6h7M6 2.5 9.5 6 6 9.5"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
        <a class="btn btn-ghost" href="#how">{t.hero.ctaGhost}</a>
      </div>
    </div>

    <a class="scroll-cue reveal d3" href="#features" aria-label={t.hero.scroll}>
      <span class="scroll-cue-label">{t.hero.scroll}</span>
      <span class="scroll-cue-rail" aria-hidden="true">
        <svg width="14" height="44" viewBox="0 0 14 44" fill="none">
          <path d="M7 2 v30" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
          <path d="M2 28 l5 6 5-6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </a>

    <div class="hero-meta reveal">
      {t.hero.meta.map((cell) => (
        <div class="meta-cell">
          <div class="num">{cell.em ? <em>{cell.num}</em> : cell.num}</div>
          <div class="label">{cell.label}</div>
        </div>
      ))}
    </div>
  </div>
</header>
