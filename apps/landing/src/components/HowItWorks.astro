---
import { getStrings, type Lang } from '../i18n/strings';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getStrings(lang);
---

<section id="how">
  <div class="wrap">
    <div class="section-head reveal">
      <div class="section-label">
        <span class="section-label__num">{t.flow.label.num}</span>
        <span class="section-label__sep">/</span>
        <span class="section-label__text">{t.flow.label.text}</span>
      </div>
      <h2 class="heading">
        {t.flow.heading.before}<em>{t.flow.heading.em}</em>{t.flow.heading.after}
      </h2>
      <p class="section-sub">{t.flow.sub}</p>
    </div>

    <div class="flow">
      <div class="editor reveal">
        <div class="editor-head">
          <div class="editor-tabs">
            <span class="tab">{t.flow.editor.tabs.overview}</span>
            <span class="tab active">{t.flow.editor.tabs.edit}</span>
            <span class="tab">{t.flow.editor.tabs.revisions}</span>
            <span class="tab">{t.flow.editor.tabs.deploy}</span>
          </div>
          <div class="editor-meta"><span class="v">v.03</span>almanac.noctua.co</div>
        </div>
        <div class="editor-body">
          <div class="editor-side">
            <div class="schema-label">Schema</div>
            <ul>
              <li><span class="t">§</span> pages</li>
              <li class="active"><span class="t">¶</span> essays</li>
              <li><span class="t">◇</span> projects</li>
              <li><span class="t">☉</span> contributors</li>
              <li><span class="t">◈</span> masthead</li>
            </ul>
          </div>
          <div class="editor-main">
            <div class="editor-field">
              <label>{t.flow.editor.labelTitle}</label>
              <div class="val focus">
                {t.flow.editor.title.before}<em>{t.flow.editor.title.em}</em>{t.flow.editor.title.after}
              </div>
            </div>
            <div class="editor-field">
              <label>{t.flow.editor.labelDek}</label>
              <div class="txt">{t.flow.editor.dek}</div>
            </div>
            <div class="editor-field">
              <label>{t.flow.editor.labelTags}</label>
              <div class="txt" style="font-family: var(--mono); font-size: 12px; color: var(--ink-mute);">
                {t.flow.editor.tags}
              </div>
            </div>
          </div>
        </div>
        <div class="editor-foot">
          <span>{t.flow.editor.saved}</span>
          <span class="publish">{t.flow.editor.publish}</span>
        </div>
      </div>

      <div class="steps reveal d1">
        {t.flow.steps.map((step, i) => (
          <div class="step">
            <div class="n">{String(i + 1).padStart(2, '0')}/</div>
            <div>
              <h4>{step.heading}</h4>
              <p>{step.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
