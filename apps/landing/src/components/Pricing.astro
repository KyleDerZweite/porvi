<section id="pricing">
  <div class="wrap">
    <div class="section-head reveal">
      <div class="section-label"><span class="rn">IV.</span> Plans</div>
      <h2 class="heading">Direct, like the <em>rest of it.</em></h2>
      <p class="section-sub">
        Plans scale with the shape of the work - a personal site, a studio, a
        small editorial group. No seat math, no hidden tiers, no trials that
        expire mid-sentence.
      </p>
    </div>

    <div class="pricing reveal">
      <div class="plan">
        <div class="plan-name">Personal</div>
        <div class="price">Free<small>during preview</small></div>
        <p class="plan-desc">
          For one person and a couple of sites. Everything you need to keep a
          small home on the web.
        </p>
        <ul>
          <li>Up to 2 sites</li>
          <li>Custom domains, certs included</li>
          <li>Versioned publishing</li>
          <li>30-day revision history</li>
          <li>Console &amp; repo authoring</li>
        </ul>
        <a class="plan-cta" href="#cta">Request access</a>
      </div>

      <div class="plan featured">
        <div class="plan-name">Studio</div>
        <div class="price">$6<small>/ month</small></div>
        <p class="plan-desc">
          For the prolific - essays, a journal, a portfolio, or three. Private
          repos, longer history, quiet analytics.
        </p>
        <ul>
          <li>Unlimited sites</li>
          <li>Private repositories</li>
          <li>90-day revision history</li>
          <li>Preview-branch access control</li>
          <li>Honest, server-side analytics</li>
        </ul>
        <a class="plan-cta" href="#cta">Start the studio</a>
      </div>

      <div class="plan">
        <div class="plan-name">Collective</div>
        <div class="price">$18<small>/ month</small></div>
        <p class="plan-desc">
          For a small group publishing together. Shared authorship, grouped
          domains, one bill.
        </p>
        <ul>
          <li>Up to 8 members</li>
          <li>Shared identity &amp; authorship</li>
          <li>Role-based access control</li>
          <li>Domain groups</li>
          <li>Priority build lane</li>
        </ul>
        <a class="plan-cta" href="#cta">Gather the group</a>
      </div>
    </div>
  </div>
</section>
