---
import { getStrings, type Lang } from '../i18n/strings';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getStrings(lang);
---

<section id="pricing">
  <div class="wrap">
    <div class="section-head reveal">
      <div class="section-label">
        <span class="section-label__num">{t.pricing.label.num}</span>
        <span class="section-label__sep">/</span>
        <span class="section-label__text">{t.pricing.label.text}</span>
      </div>
      <h2 class="heading">
        {t.pricing.heading.before}<em>{t.pricing.heading.em}</em>
      </h2>
      <p class="section-sub">{t.pricing.sub}</p>
    </div>

    <div class="pricing reveal">
      <div class="plan">
        <div class="plan-name">{t.pricing.personal.name}</div>
        <div class="price">
          <span>{lang === 'de' ? 'Frei' : 'Free'}</span>
          <small>{t.pricing.duringPreview}</small>
        </div>
        <p class="plan-desc">{t.pricing.personal.desc}</p>
        <ul>
          {t.pricing.personal.items.map((item) => <li>{item}</li>)}
        </ul>
        <a class="plan-cta" href="#cta">{t.pricing.personal.cta}</a>
      </div>

      <div class="plan featured">
        <div class="plan-name">{t.pricing.studio.name}</div>
        <div class="price">
          <span>{lang === 'de' ? 'Individuell' : 'Custom'}</span>
          <small>{t.pricing.perMonth}</small>
        </div>
        <p class="plan-desc">{t.pricing.studio.desc}</p>
        <ul>
          {t.pricing.studio.items.map((item) => <li>{item}</li>)}
        </ul>
        <a class="plan-cta" href="#cta">{t.pricing.studio.cta}</a>
      </div>
    </div>
  </div>
</section>
