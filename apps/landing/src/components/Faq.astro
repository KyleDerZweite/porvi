---
import { getStrings, type Lang } from '../i18n/strings';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getStrings(lang);
---

<section id="faq">
  <div class="wrap">
    <div class="section-head reveal">
      <div class="section-label">
        <span class="section-label__num">{t.faq.label.num}</span>
        <span class="section-label__sep">/</span>
        <span class="section-label__text">{t.faq.label.text}</span>
      </div>
      <h2 class="heading">{t.faq.heading}</h2>
    </div>

    <div class="faq reveal">
      {t.faq.items.map((item, i) => (
        <details class="qa" open={i === 0}>
          <summary>{item.q} <span class="plus" aria-hidden="true">+</span></summary>
          <div class="answer">{item.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>
