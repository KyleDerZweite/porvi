---
---

<section id="showcase">
  <div class="wrap">
    <div class="section-head reveal">
      <div class="section-label"><span class="rn">III.</span> In the wild</div>
      <h2 class="heading">A few <em>sites</em> kept on Porvi.</h2>
      <p class="section-sub">
        Each one is its own project - different typography, different rhythm,
        different voice. Same structured editing and versioned publishing
        underneath.
      </p>
    </div>

    <div class="showcase">
      <div class="site-card reveal">
        <div class="site-frame">
          <svg class="art-svg" viewBox="0 0 400 250" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
              <pattern id="p-stripes-1" width="10" height="10" patternUnits="userSpaceOnUse" patternTransform="rotate(30)">
                <rect width="10" height="10" fill="#ece7da" />
                <rect width="0.6" height="10" fill="#d7d0be" />
              </pattern>
            </defs>
            <rect width="400" height="250" fill="url(#p-stripes-1)" />
            <text x="30" y="58" font-family="Fraunces" font-size="38" fill="#18160f" font-weight="400">Noctua</text>
            <text x="30" y="82" font-family="JetBrains Mono" font-size="9.5" fill="#6a6357" letter-spacing="2">AN ALMANAC · SPRING 2026</text>
            <rect x="30" y="108" width="180" height="3" fill="#3d382a" />
            <rect x="30" y="120" width="260" height="3" fill="#8d8675" opacity="0.6" />
            <rect x="30" y="132" width="220" height="3" fill="#8d8675" opacity="0.6" />
            <circle cx="330" cy="176" r="38" fill="none" stroke="#b54828" stroke-width="0.8" />
            <circle cx="330" cy="176" r="4" fill="#b54828" />
          </svg>
        </div>
        <div class="site-foot">
          <span class="domain">almanac.noctua.co</span>
          <span class="status"><span class="live"></span> Live · v.03</span>
        </div>
      </div>

      <div class="site-card reveal d1">
        <div class="site-frame">
          <svg class="art-svg" viewBox="0 0 400 250" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
              <pattern id="p-grid-1" width="22" height="22" patternUnits="userSpaceOnUse">
                <rect width="22" height="22" fill="#f3efe6" />
                <path d="M22 0 L0 0 0 22" stroke="#e4decd" stroke-width="1" fill="none" />
              </pattern>
            </defs>
            <rect width="400" height="250" fill="url(#p-grid-1)" />
            <text x="30" y="68" font-family="Fraunces" font-size="52" fill="#18160f" font-style="italic" font-weight="380">field notes</text>
            <text x="30" y="98" font-family="JetBrains Mono" font-size="9.5" fill="#6a6357" letter-spacing="2">BY C. ORELL · EST. 2021</text>
            <rect x="30" y="138" width="340" height="3" fill="#8d8675" opacity="0.6" />
            <rect x="30" y="150" width="300" height="3" fill="#8d8675" opacity="0.6" />
            <rect x="30" y="162" width="340" height="3" fill="#8d8675" opacity="0.6" />
            <rect x="30" y="174" width="180" height="3" fill="#8d8675" opacity="0.6" />
          </svg>
        </div>
        <div class="site-foot">
          <span class="domain">fieldnotes.orell.me</span>
          <span class="status"><span class="live"></span> Live · v.18</span>
        </div>
      </div>

      <div class="site-card reveal d2">
        <div class="site-frame">
          <svg class="art-svg" viewBox="0 0 400 250" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
              <linearGradient id="grad-1" x1="0" x2="1" y1="0" y2="1">
                <stop offset="0" stop-color="#ece7da" />
                <stop offset="0.5" stop-color="#e3dccb" />
                <stop offset="1" stop-color="#d7d0be" />
              </linearGradient>
            </defs>
            <rect width="400" height="250" fill="url(#grad-1)" />
            <g transform="translate(200 125)">
              <circle r="70" fill="none" stroke="#b54828" stroke-width="0.6" />
              <circle r="50" fill="none" stroke="#b54828" stroke-width="0.6" />
              <circle r="30" fill="none" stroke="#b54828" stroke-width="0.6" />
              <circle r="3" fill="#b54828" />
            </g>
            <text x="30" y="38" font-family="JetBrains Mono" font-size="9.5" fill="#6a6357" letter-spacing="2">PORTFOLIO · R.K.</text>
            <text x="30" y="232" font-family="Fraunces" font-size="24" fill="#18160f" font-weight="400">selected works</text>
          </svg>
        </div>
        <div class="site-foot">
          <span class="domain">rk.studio</span>
          <span class="status"><span class="live"></span> Live · v.07</span>
        </div>
      </div>
    </div>
  </div>
</section>
