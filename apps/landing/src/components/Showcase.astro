---
---

<section id="showcase">
  <div class="wrap">
    <div class="section-label"><span class="idx">03 -</span> The shelf</div>
    <h2 class="heading">Sites our circle has been keeping.</h2>
    <p class="section-sub">
      A few of the corners of the web that live on Porvi. Each one is its own small
      project - different typography, different rhythm, same calm pipeline underneath.
    </p>

    <div class="showcase">
      <div class="site-card">
        <div class="site-frame">
          <svg class="art-svg" viewBox="0 0 400 250" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
              <pattern id="p-stripes-1" width="10" height="10" patternUnits="userSpaceOnUse" patternTransform="rotate(30)">
                <rect width="10" height="10" fill="#1f1a13" />
                <rect width="1" height="10" fill="#2a241b" />
              </pattern>
            </defs>
            <rect width="400" height="250" fill="url(#p-stripes-1)" />
            <text x="30" y="54" font-family="Instrument Serif" font-size="34" fill="#f4ede0">Noctua</text>
            <text x="30" y="78" font-family="Geist Mono" font-size="10" fill="#8a8573" letter-spacing="2">AN ALMANAC · 2026</text>
            <rect x="30" y="100" width="180" height="4" fill="#3a3123" />
            <rect x="30" y="112" width="260" height="4" fill="#2a241b" />
            <rect x="30" y="124" width="220" height="4" fill="#2a241b" />
            <circle cx="330" cy="170" r="38" fill="none" stroke="#d9a066" stroke-width="0.8" />
            <circle cx="330" cy="170" r="4" fill="#d9a066" />
          </svg>
        </div>
        <div class="site-foot">
          <span class="domain">almanac.noctua.co</span>
          <span class="status"><span class="live"></span> Live</span>
        </div>
      </div>

      <div class="site-card">
        <div class="site-frame">
          <svg class="art-svg" viewBox="0 0 400 250" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
              <pattern id="p-grid-1" width="20" height="20" patternUnits="userSpaceOnUse">
                <rect width="20" height="20" fill="#141109" />
                <path d="M20 0 L0 0 0 20" stroke="#1f1a13" stroke-width="1" fill="none" />
              </pattern>
            </defs>
            <rect width="400" height="250" fill="url(#p-grid-1)" />
            <text x="30" y="60" font-family="Instrument Serif" font-size="48" fill="#f4ede0" font-style="italic">field notes</text>
            <text x="30" y="92" font-family="Geist Mono" font-size="10" fill="#8a8573" letter-spacing="2">BY C. ORELL · EST. 2021</text>
            <rect x="30" y="130" width="340" height="4" fill="#2a241b" />
            <rect x="30" y="142" width="300" height="4" fill="#2a241b" />
            <rect x="30" y="154" width="340" height="4" fill="#2a241b" />
            <rect x="30" y="166" width="180" height="4" fill="#2a241b" />
          </svg>
        </div>
        <div class="site-foot">
          <span class="domain">fieldnotes.orell.me</span>
          <span class="status"><span class="live"></span> Live</span>
        </div>
      </div>

      <div class="site-card">
        <div class="site-frame">
          <svg class="art-svg" viewBox="0 0 400 250" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
              <linearGradient id="grad-1" x1="0" x2="1" y1="0" y2="1">
                <stop offset="0" stop-color="#2a241b" />
                <stop offset="0.5" stop-color="#1c1812" />
                <stop offset="1" stop-color="#141109" />
              </linearGradient>
            </defs>
            <rect width="400" height="250" fill="url(#grad-1)" />
            <g transform="translate(200 125)">
              <circle r="70" fill="none" stroke="#d9a066" stroke-width="0.6" />
              <circle r="50" fill="none" stroke="#d9a066" stroke-width="0.6" />
              <circle r="30" fill="none" stroke="#d9a066" stroke-width="0.6" />
              <circle r="3" fill="#d9a066" />
            </g>
            <text x="30" y="38" font-family="Geist Mono" font-size="10" fill="#8a8573" letter-spacing="2">PORTFOLIO · R.K.</text>
            <text x="30" y="232" font-family="Instrument Serif" font-size="22" fill="#f4ede0">selected works</text>
          </svg>
        </div>
        <div class="site-foot">
          <span class="domain">rk.studio</span>
          <span class="status"><span class="live"></span> Live</span>
        </div>
      </div>
    </div>
  </div>
</section>
