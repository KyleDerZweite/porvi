---
import { getStrings, type Lang } from '../i18n/strings';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getStrings(lang);
---

<section id="features">
  <div class="wrap">
    <div class="section-head reveal">
      <div class="section-label">
        <span class="section-label__num">{t.features.label.num}</span>
        <span class="section-label__sep">/</span>
        <span class="section-label__text">{t.features.label.text}</span>
      </div>
      <h2 class="heading">
        {t.features.heading.before}<em>{t.features.heading.em}</em>{t.features.heading.after}
      </h2>
      <p class="section-sub">{t.features.sub}</p>
    </div>

    <div class="features reveal">
      <div class="feat span-3">
        <div class="feat-label">{t.features.structure.label}</div>
        <h3>{t.features.structure.heading.before}<em>{t.features.structure.heading.em}</em></h3>
        <p>{t.features.structure.body}</p>
        <div class="feat-art">
          <svg class="art-svg" viewBox="0 0 600 180" aria-hidden="true">
            <defs>
              <pattern id="hatch-a" width="6" height="6" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
                <rect width="6" height="6" fill="transparent" />
                <rect width="0.6" height="6" fill="#d7d0be" />
              </pattern>
            </defs>
            <rect x="30" y="26" width="540" height="128" rx="8" fill="#ece7da" stroke="#d7d0be" />
            <rect x="30" y="26" width="540" height="128" rx="8" fill="url(#hatch-a)" opacity="0.5" />
            <g font-family="JetBrains Mono" font-size="11" fill="#6a6357">
              <text x="52" y="54">essay</text>
              <text x="52" y="74" fill="#8d8675">├─ title <tspan fill="#b54828">string</tspan></text>
              <text x="52" y="92" fill="#8d8675">├─ body <tspan fill="#b54828">mdx</tspan></text>
              <text x="52" y="110" fill="#8d8675">├─ tags <tspan fill="#b54828">string[]</tspan></text>
              <text x="52" y="128" fill="#8d8675">└─ published <tspan fill="#b54828">date</tspan></text>
            </g>
            <g transform="translate(330 40)">
              <rect width="220" height="110" rx="6" fill="#f3efe6" stroke="#d7d0be" />
              <text x="16" y="34" font-family="Fraunces" font-size="18" fill="#18160f">The March Entries</text>
              <rect x="16" y="50" width="160" height="3" fill="#d7d0be" />
              <rect x="16" y="62" width="180" height="3" fill="#e4decd" />
              <rect x="16" y="72" width="140" height="3" fill="#e4decd" />
              <rect x="16" y="88" width="60" height="10" rx="5" fill="#b54828" opacity="0.16" />
              <text x="20" y="96" font-family="JetBrains Mono" font-size="8.5" fill="#b54828">ESSAY</text>
            </g>
          </svg>
        </div>
      </div>

      <div class="feat span-3">
        <div class="feat-label">{t.features.versions.label}</div>
        <h3>{t.features.versions.heading}</h3>
        <p>{t.features.versions.body}</p>
        <div class="feat-art">
          <svg class="art-svg" viewBox="0 0 600 180" aria-hidden="true">
            <line x1="60" y1="90" x2="540" y2="90" stroke="#d7d0be" />
            <g font-family="JetBrains Mono" font-size="10.5">
              <g transform="translate(90 90)">
                <circle r="7" fill="#f3efe6" stroke="#8d8675" />
                <text y="28" fill="#8d8675" text-anchor="middle">v.01</text>
              </g>
              <g transform="translate(210 90)">
                <circle r="7" fill="#f3efe6" stroke="#8d8675" />
                <text y="28" fill="#8d8675" text-anchor="middle">v.02</text>
              </g>
              <g transform="translate(330 90)">
                <circle r="9" fill="#b54828" stroke="#b54828" />
                <text y="30" fill="#b54828" text-anchor="middle">v.03 · live</text>
              </g>
              <g transform="translate(450 90)">
                <circle r="7" fill="#f3efe6" stroke="#d7d0be" stroke-dasharray="2 3" />
                <text y="28" fill="#8d8675" text-anchor="middle">v.04 · draft</text>
              </g>
            </g>
            <g font-family="Fraunces" font-size="11" font-style="italic" fill="#6a6357">
              <text x="74" y="58">spring opens</text>
              <text x="196" y="58">contributors</text>
              <text x="312" y="58">new masthead</text>
              <text x="434" y="58">next issue</text>
            </g>
          </svg>
        </div>
      </div>

      <div class="feat span-2">
        <div class="feat-label">{t.features.domains.label}</div>
        <h3>{t.features.domains.heading}</h3>
        <p>{t.features.domains.body}</p>
        <div class="feat-art">
          <svg class="art-svg" viewBox="0 0 320 140" aria-hidden="true">
            <g font-family="JetBrains Mono" font-size="10.5" fill="#6a6357">
              <rect x="14" y="28" width="130" height="32" rx="4" fill="#f3efe6" stroke="#d7d0be" />
              <text x="26" y="48" fill="#18160f">your.domain</text>
              <rect x="174" y="28" width="130" height="32" rx="4" fill="#f3efe6" stroke="#b54828" />
              <text x="186" y="48" fill="#b54828">porvi edge</text>
              <path d="M144 44 h30" stroke="#8d8675" stroke-dasharray="2 3" />
              <rect x="14" y="82" width="290" height="36" rx="4" fill="#ece7da" stroke="#d7d0be" />
              <text x="28" y="105" fill="#4a7a4e">● certificate issued · 90-day auto-renew</text>
            </g>
          </svg>
        </div>
      </div>

      <div class="feat span-2">
        <div class="feat-label">{t.features.deploys.label}</div>
        <h3>{t.features.deploys.heading}</h3>
        <p>{t.features.deploys.body}</p>
        <div class="feat-art">
          <svg class="art-svg" viewBox="0 0 320 140" aria-hidden="true">
            <rect x="14" y="14" width="292" height="112" rx="8" fill="#ece7da" stroke="#d7d0be" />
            <g font-family="JetBrains Mono" font-size="10.5">
              <text x="30" y="42" fill="#8d8675">▸ render · 238 routes</text>
              <text x="30" y="60" fill="#8d8675">▸ hash · 3a9f · 41 files new</text>
              <text x="30" y="78" fill="#4a7a4e">✓ build · 11.8s</text>
              <text x="30" y="104" fill="#b54828">● live · your.domain</text>
            </g>
          </svg>
        </div>
      </div>

      <div class="feat span-2">
        <div class="feat-label">{t.features.console.label}</div>
        <h3>{t.features.console.heading}</h3>
        <p>{t.features.console.body}</p>
        <div class="feat-art">
          <svg class="art-svg" viewBox="0 0 320 140" aria-hidden="true">
            <g transform="translate(160 70)">
              <circle r="26" fill="#f3efe6" stroke="#b54828" />
              <text y="6" text-anchor="middle" font-family="Fraunces" font-style="italic" font-size="22" fill="#b54828">o</text>
            </g>
            <g stroke="#d7d0be" stroke-dasharray="2 3" fill="none">
              <line x1="70" y1="40" x2="140" y2="60" />
              <line x1="250" y1="40" x2="180" y2="60" />
              <line x1="70" y1="100" x2="140" y2="80" />
              <line x1="250" y1="100" x2="180" y2="80" />
            </g>
            <g fill="#f3efe6" stroke="#d7d0be">
              <rect x="36" y="22" width="60" height="30" rx="4" />
              <rect x="224" y="22" width="60" height="30" rx="4" />
              <rect x="36" y="88" width="60" height="30" rx="4" />
              <rect x="224" y="88" width="60" height="30" rx="4" />
            </g>
            <g font-family="JetBrains Mono" font-size="9" fill="#8d8675">
              <text x="46" y="41">almanac</text>
              <text x="234" y="41">studio</text>
              <text x="50" y="107">journal</text>
              <text x="238" y="107">folio</text>
            </g>
          </svg>
        </div>
      </div>

      <div class="feat span-6" style="min-height:auto; padding: 26px 32px;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap: 24px; flex-wrap: wrap;">
          <div style="display:flex; gap:28px; align-items:center; color: var(--ink-2); font-size: 14px; flex-wrap: wrap;">
            <span style="font-family: var(--mono); font-size: 11px; letter-spacing:.14em; text-transform:uppercase; color: var(--ink-mute);">{t.features.also.label}</span>
            {t.features.also.items.map((item) => <span>{item}</span>)}
          </div>
          <a href="#how" style="font-size: 13px; color: var(--accent); font-family: var(--mono); letter-spacing: 0.04em;">{t.features.also.cta}</a>
        </div>
      </div>
    </div>
  </div>
</section>
