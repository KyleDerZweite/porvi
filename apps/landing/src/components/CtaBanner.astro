---
---

<section id="cta" style="padding-top: 0;">
  <div class="wrap">
    <div class="cta-banner">
      <div>
        <h3>Keep a <em>small, good thing</em> on the internet.</h3>
        <p>
          Invites go out in small batches. Leave a note about what you'd build, and we'll be
          in touch when there's room.
        </p>
      </div>
      <div class="cta-right">
        <form id="invite-form" class="invite-form">
          <input type="email" required placeholder="you@domain.tld" />
          <button type="submit" class="btn btn-primary" style="height: 46px;">Request invite</button>
        </form>
        <span style="font-family: var(--mono); font-size: 11px; color: var(--paper-mute); letter-spacing: 0.04em;">
          One email, when a spot opens. No list.
        </span>
      </div>
    </div>
  </div>
</section>

<script>
  const inviteForm = document.getElementById('invite-form');
  inviteForm?.addEventListener('submit', (event) => {
    event.preventDefault();
    const button = inviteForm.querySelector('button');
    if (button) button.textContent = 'Sent ✓';
  });
</script>
