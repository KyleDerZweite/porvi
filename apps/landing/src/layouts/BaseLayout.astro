---
import '../styles/global.css';
import { ALT_LANG, DEFAULT_LANG, HREFLANG, PATH_FOR_LANG, type Lang } from '../i18n/strings';

interface Props {
  lang?: Lang;
  title: string;
  description: string;
}

const { lang = DEFAULT_LANG, title, description } = Astro.props;
const altLang = ALT_LANG[lang];
const sitePath = PATH_FOR_LANG[lang];
const altPath = PATH_FOR_LANG[altLang];
---

<!doctype html>
<html lang={HREFLANG[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="oklch(0.965 0.006 170)" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="oklch(0.15 0.010 170)" media="(prefers-color-scheme: dark)" />
    <link rel="alternate" hreflang={HREFLANG[lang]} href={sitePath} />
    <link rel="alternate" hreflang={HREFLANG[altLang]} href={altPath} />
    <link rel="alternate" hreflang="x-default" href={PATH_FOR_LANG[DEFAULT_LANG]} />
    <script is:inline>
      const requestedTheme = new URLSearchParams(window.location.search).get('theme');
      if (requestedTheme === 'light' || requestedTheme === 'dark') {
        localStorage.setItem('porvi-theme', requestedTheme);
      }
      const theme = localStorage.getItem('porvi-theme');
      if (theme === 'light' || theme === 'dark') {
        document.documentElement.dataset.theme = theme;
      } else {
        document.documentElement.dataset.theme = 'light';
      }
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'de' ? 'de_DE' : 'en_US'} />
    <meta property="og:locale:alternate" content={altLang === 'de' ? 'de_DE' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <div class="bg" aria-hidden="true"></div>
    <div class="page">
      <slot />
    </div>
  </body>
</html>
