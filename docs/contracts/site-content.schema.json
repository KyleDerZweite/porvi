{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://porvi.dev/contracts/site-content.schema.json",
  "title": "Porvi Site Content",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile", "pages"],
  "properties": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "handle", "bio"],
      "properties": {
        "name": { "type": "string" },
        "handle": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "location": { "type": "string" },
        "availability": { "type": "string" }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "title", "sections"],
        "properties": {
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "navLabel": { "type": "string" },
          "description": { "type": "string" },
          "hero": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "eyebrow": { "type": "string" },
              "title": { "type": "string" },
              "subtitle": { "type": "string" },
              "kicker": { "type": "string" },
              "primaryCta": { "$ref": "#/$defs/button" },
              "secondaryCta": { "$ref": "#/$defs/button" }
            }
          },
          "sections": {
            "type": "array",
            "items": { "$ref": "#/$defs/section" }
          }
        }
      }
    }
  },
  "$defs": {
    "button": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "href"],
      "properties": {
        "label": { "type": "string" },
        "href": { "type": "string" }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": true
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["text", "links", "featured", "embeds", "cta"]
        },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "anchor": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/item" }
        },
        "button": { "$ref": "#/$defs/button" }
      }
    }
  }
}
