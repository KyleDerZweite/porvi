# Porvi Environment Variables
# Copy to .env and fill in your values

# Platform API runtime
PLATFORM_PORT=3000
PLATFORM_DATABASE_DIALECT=sqlite
PLATFORM_SQLITE_PATH=.porvi/platform.sqlite
# PLATFORM_DATABASE_URL=postgres://user:password@localhost:5432/porvi
# PLATFORM_REPO_ROOT=/srv/porvi

# Public origins
PLATFORM_PUBLIC_API_URL=http://localhost:3000
PLATFORM_PUBLIC_APP_URL=http://localhost:5173
PLATFORM_PUBLIC_WEB_URL=http://localhost:4321
VITE_PLATFORM_API_URL=http://localhost:3000
PUBLIC_PLATFORM_API_URL=http://localhost:3000
PUBLIC_PLATFORM_APP_URL=http://localhost:5173

# Session configuration
# Use a plain cookie name for localhost HTTP development.
# Switch to __Host-porvi_session when the API is served over HTTPS.
PLATFORM_SESSION_COOKIE_NAME=porvi_session
PLATFORM_SESSION_TTL_SECONDS=604800

# Build/publish paths
PLATFORM_PUBLISH_ROOT=.porvi/published
PLATFORM_PREVIEW_ROOT=.porvi/previews
# PLATFORM_NGINX_MAP_PATH=/etc/nginx/porvi-hosts.map

# Optional auth provider bootstrap directory
# Each file should contain one auth provider config matching docs/contracts/auth-provider.schema.json
PLATFORM_PROVIDER_CONFIG_DIR=./configs/providers

# Zitadel / OIDC
# The Zitadel app should allow the localhost callback and app origins used here:
# - http://localhost:3000/v1/auth/callback/zitadel
# - http://localhost:5173/
# - http://localhost:4321/
PORVI_ZITADEL_ISSUER=https://auth.kylehub.dev
PORVI_ZITADEL_WEB_CLIENT_ID=367086772372373509
# Public PKCE clients can use `none`
PORVI_ZITADEL_WEB_CLIENT_SECRET_REF=none

# Optional service-user credentials for Zitadel management API probes
PORVI_ZITADEL_SERVICE_USER_CLIENT_ID=api-playground
PORVI_ZITADEL_SERVICE_USER_CLIENT_SECRET=replace-me
PORVI_ZITADEL_PROJECT_ID=367086328984109061
